PORT=3001

# Comma-separated frontend origins allowed by CORS.
# Example (Vercel + Cloudflare Pages):
# CORS_ORIGIN=http://localhost:5173,https://your-app.vercel.app,https://your-app.pages.dev
CORS_ORIGIN=http://localhost:5173

# Optional: override SQLite location (absolute path or relative to process cwd).
# Default when unset: backend/database.sqlite
# DATABASE_PATH=./database.sqlite

# Optional for LLM-backed answers.
GEMINI_API_KEY=

# Optional for Groq-backed answers (Groq is compatible with OpenAI-style chat completions).
# If GROQ_API_KEY is set, the backend will prefer Groq automatically (unless LLM_PROVIDER is set).
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Optional: force provider. Values: `groq` or `gemini`.
# If unset: auto-picks Groq when GROQ_API_KEY is present; otherwise Gemini.
LLM_PROVIDER=
